<UserControl x:Class="FaceDiff.Views.AlignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="250" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel: selectors -->
        <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Destination folder (shown when Step 3 not yet unlocked) -->
                <StackPanel Grid.Row="0"
                            Visibility="{Binding ShowDestinationField, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,8">
                    <TextBlock Text="Destination Folder" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse..."
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BrowseDestinationCommand}"
                                Margin="8,0,0,0" />
                        <TextBox Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <TextBlock FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0">
                        <Run Text="Preview: " /><Run Text="{Binding DestinationPathPreview, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <!-- Base image selector -->
                <TextBlock Grid.Row="1" Text="Base Image (Pose)"
                           Style="{StaticResource SectionHeader}" />
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding ProcessedBaseImages}"
                         SelectedItem="{Binding SelectedBaseImage}"
                         DisplayMemberPath="FileName"
                         Background="Transparent"
                         Foreground="{StaticResource TextBrush}"
                         BorderThickness="0"
                         Margin="0,0,0,8" />

                <!-- Outfit image selector -->
                <TextBlock Grid.Row="3" Text="Outfit Variant"
                           Style="{StaticResource SectionHeader}" />
                <ListBox Grid.Row="4"
                         ItemsSource="{Binding OutfitImages}"
                         SelectedItem="{Binding SelectedOutfitPath}"
                         Background="Transparent"
                         Foreground="{StaticResource TextBrush}"
                         BorderThickness="0"
                         Margin="0,0,0,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource FileNameConverter}}"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Diff image selector -->
                <TextBlock Grid.Row="5" Text="Diff Image"
                           Style="{StaticResource SectionHeader}" />
                <ListBox Grid.Row="6"
                         ItemsSource="{Binding DiffImages}"
                         SelectedItem="{Binding SelectedDiffPath}"
                         Background="Transparent"
                         Foreground="{StaticResource TextBrush}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource FileNameConverter}}"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right panel: preview + alignment controls -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Preview area with zoom/pan -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    ClipToBounds="True" Background="Black"
                    x:Name="PreviewBorder"
                    PreviewMouseWheel="PreviewBorder_PreviewMouseWheel"
                    MouseLeftButtonDown="PreviewBorder_MouseLeftButtonDown"
                    MouseLeftButtonUp="PreviewBorder_MouseLeftButtonUp"
                    MouseMove="PreviewBorder_MouseMove"
                    MouseLeave="PreviewBorder_MouseLeave">
                <Grid>
                    <!-- Canvas positions (not RenderTransform on Uniform Image) so DIP offsets match Ren'Py. -->
                    <Canvas x:Name="PreviewContainer" SizeChanged="PreviewContainer_SizeChanged"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="PreviewScale"
                                                ScaleX="{Binding ZoomLevel}"
                                                ScaleY="{Binding ZoomLevel}" />
                                <TranslateTransform x:Name="PreviewTranslate" />
                            </TransformGroup>
                        </Canvas.RenderTransform>

                        <Image Source="{Binding OutfitDisplay}"
                               Canvas.Left="{Binding OutfitImageLeft}"
                               Canvas.Top="0"
                               Width="{Binding RenderedImageWidth}"
                               Height="{Binding RenderedImageHeight}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />

                        <Image Source="{Binding DiffDisplay}"
                               Canvas.Left="{Binding DiffImageLeft}"
                               Canvas.Top="{Binding DiffImageTop}"
                               Width="{Binding RenderedImageWidth}"
                               Height="{Binding RenderedImageHeight}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Canvas>

                    <!-- Preview zoom: WPF-only magnification for inspection. Alignment math uses layout size, not ZoomLevel. -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,12,12">
                        <Button Content="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                Command="{Binding ZoomOutCommand}"
                                Width="32" Height="32" Padding="0"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                                ToolTip="Zoom out (wheel without modifiers also zooms toward cursor)" />
                        <Button Content="Fit" FontSize="11"
                                Command="{Binding ZoomFitCommand}"
                                Width="32" Height="32" Padding="0"
                                Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                                ToolTip="Fit preview (reset zoom and pan)" />
                        <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                Command="{Binding ZoomInCommand}"
                                Width="32" Height="32" Padding="0"
                                Style="{StaticResource PrimaryButton}"
                                ToolTip="Zoom in (wheel without modifiers also zooms toward cursor)" />
                    </StackPanel>

                    <!-- Active axis indicator (top-right) -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,12,0" Padding="8,4"
                            Background="#88000000" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Scroll axis: " Foreground="{StaticResource TextDimBrush}"
                                       FontFamily="Consolas" FontSize="12" />
                            <TextBlock Text="{Binding ActiveAxisLabel}" Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold" />
                            <TextBlock Text="  (Tab: switch axis)" Foreground="{StaticResource TextDimBrush}"
                                       FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- AlignY controls (highlight when Y is active — Tab switches axis) -->
            <Border Grid.Row="1" Margin="0,8,0,0" Padding="6,4" CornerRadius="4"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsXAxisActive}" Value="False">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Background" Value="#15000000" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="ypos:"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               FontFamily="Consolas" />
                    <Slider Grid.Column="1"
                            Minimum="-0.5" Maximum="0.5"
                            Value="{Binding AlignY, Mode=TwoWay}"
                            TickFrequency="0.001" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding AlignY, StringFormat='{}{0:F6}'}"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="8,0,8,0"
                               FontFamily="Consolas" MinWidth="70" />
                    <TextBox Grid.Column="3"
                             Text="{Binding AlignY, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F6}'}"
                             FontFamily="Consolas" VerticalAlignment="Center"
                             HorizontalContentAlignment="Right" />
                </Grid>
            </Border>

            <!-- AlignX controls -->
            <Border Grid.Row="2" Margin="0,4,0,0" Padding="6,4" CornerRadius="4"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsXAxisActive}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Background" Value="#15000000" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="xalign:"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               FontFamily="Consolas" />
                    <Slider Grid.Column="1"
                            Minimum="-0.5" Maximum="0.5"
                            Value="{Binding AlignX, Mode=TwoWay}"
                            TickFrequency="0.001" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding AlignX, StringFormat='{}{0:F6}'}"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="8,0,8,0"
                               FontFamily="Consolas" MinWidth="70" />
                    <TextBox Grid.Column="3"
                             Text="{Binding AlignX, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F6}'}"
                             FontFamily="Consolas" VerticalAlignment="Center"
                             HorizontalContentAlignment="Right" />
                </Grid>
            </Border>

            <!-- Viewport = Ren'Py reference size for float xalign / ypos (usually config.screen_width × screen_height). -->
            <StackPanel Grid.Row="3" Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Viewport:"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               FontFamily="Consolas" FontSize="11" />
                    <TextBox Text="{Binding ViewportWidth, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" VerticalAlignment="Center"
                             Width="60" HorizontalContentAlignment="Right"
                             FontSize="11" />
                    <TextBlock Text="x"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="4,0,4,0"
                               FontFamily="Consolas" FontSize="11" />
                    <TextBox Text="{Binding ViewportHeight, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" VerticalAlignment="Center"
                             Width="60" HorizontalContentAlignment="Right"
                             FontSize="11" />
                    <TextBlock Text="px"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="4,0,8,0"
                               FontFamily="Consolas" FontSize="11" />
                    <Button Content="Use image height"
                            Command="{Binding UseImageHeightAsViewportHeightCommand}"
                            FontSize="10" Padding="6,2"
                            ToolTip="Set viewport height to the outfit image pixel height (match ypos reference if sprites use full-screen area)." />
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextDimBrush}"
                           FontFamily="Consolas" FontSize="9" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="These xalign / ypos numbers are the layer overrides (offset from the paperdoll base for the diff layer). Set viewport to config.screen_width × config.screen_height. Use “Use image height” if that matches your ypos area." />
            </StackPanel>

            <!-- Debug info for alignment diagnostics -->
            <TextBlock Grid.Row="4" Text="{Binding DebugInfo}"
                       Foreground="{StaticResource TextDimBrush}"
                       FontFamily="Consolas" FontSize="9"
                       Margin="0,4,0,0" TextWrapping="Wrap" />
        </Grid>
    </Grid>
</UserControl>
