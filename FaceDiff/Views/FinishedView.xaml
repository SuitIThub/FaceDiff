<UserControl x:Class="FaceDiff.Views.FinishedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Processing Complete"
                   Style="{StaticResource SectionHeader}" FontSize="20"
                   Margin="0,0,0,16" />

        <!-- Statistics -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceLightBrush}"
                CornerRadius="8" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalBaseImages}"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="Base Images" Foreground="{StaticResource TextDimBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalComparisons}"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="Comparisons" Foreground="{StaticResource TextDimBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding AcceptedCount}"
                               Foreground="#4CAF50"
                               FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="Accepted" Foreground="{StaticResource TextDimBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding DeniedCount}"
                               Foreground="#F44336"
                               FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="Denied" Foreground="{StaticResource TextDimBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results list -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Processed Base Images"
                           Style="{StaticResource SectionHeader}" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ResultItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceLightBrush}"
                                        CornerRadius="4" Padding="12" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding BaseImage.FileName}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   VerticalAlignment="Center"
                                                   FontSize="13" />

                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center" Margin="16,0"
                                                   Foreground="{StaticResource TextDimBrush}">
                                            <Run Text="{Binding ComparisonCount, Mode=OneWay}" />
                                            <Run Text="comparisons" />
                                        </TextBlock>

                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center" Margin="16,0">
                                            <Run Text="{Binding GeneratedDiffPaths.Count, Mode=OneWay}" />
                                            <Run Text="diffs" Foreground="{StaticResource TextDimBrush}" />
                                        </TextBlock>

                                        <Border Grid.Column="3" CornerRadius="4"
                                                Padding="12,4" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#4CAF50" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Accepted}" Value="False">
                                                            <Setter Property="Background" Value="#F44336" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Foreground="White" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Accepted" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Accepted}" Value="False">
                                                                <Setter Property="Text" Value="Denied" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Retry button -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,16,0,0"
                    Visibility="{Binding HasDenied, Converter={StaticResource BoolToVis}}">
            <Button Content="Retry Denied Base Images"
                    Style="{StaticResource AccentButton}"
                    MinWidth="200" FontSize="14" Padding="20,10"
                    Command="{Binding RetryDeniedCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
