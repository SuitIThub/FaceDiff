<UserControl x:Class="FaceDiff.Controls.OvalEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">

    <Grid>
        <ScrollViewer x:Name="ImageScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="Black">
            <Canvas x:Name="EditorCanvas"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseRightButtonDown="Canvas_MouseRightButtonDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    ClipToBounds="True"
                    Background="Transparent">
                <Image x:Name="BackgroundImage"
                       Stretch="None"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Canvas.Left="0" Canvas.Top="0" />

                <Ellipse x:Name="OvalShape"
                         Stroke="LimeGreen" StrokeThickness="2"
                         Fill="#220000FF"
                         Cursor="SizeAll" />

                <!-- Edge handles -->
                <Ellipse x:Name="HandleTop" Width="12" Height="12"
                         Fill="White" Stroke="LimeGreen" StrokeThickness="1"
                         Cursor="SizeNS"
                         MouseLeftButtonDown="Handle_MouseLeftButtonDown" />
                <Ellipse x:Name="HandleBottom" Width="12" Height="12"
                         Fill="White" Stroke="LimeGreen" StrokeThickness="1"
                         Cursor="SizeNS"
                         MouseLeftButtonDown="Handle_MouseLeftButtonDown" />
                <Ellipse x:Name="HandleLeft" Width="12" Height="12"
                         Fill="White" Stroke="LimeGreen" StrokeThickness="1"
                         Cursor="SizeWE"
                         MouseLeftButtonDown="Handle_MouseLeftButtonDown" />
                <Ellipse x:Name="HandleRight" Width="12" Height="12"
                         Fill="White" Stroke="LimeGreen" StrokeThickness="1"
                         Cursor="SizeWE"
                         MouseLeftButtonDown="Handle_MouseLeftButtonDown" />
            </Canvas>
        </ScrollViewer>

        <!-- Zoom controls -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,8,0">
            <Button Content="Zoom to Oval" Click="ZoomToOval_Click"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,4,0" FontSize="11" />
            <Button Content="Fit Image" Click="FitImage_Click"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="11" />
        </StackPanel>
    </Grid>
</UserControl>
